{
  "name": "@hpiece/docs-numbering",
  "version": "0.1.0",
  "description": "CLI-neutral numbered markdown documentation manager for AI coding CLIs",
  "author": "hpiece",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hpiece-cs/docs-numbering.git",
    "directory": "core"
  },
  "keywords": [
    "docs",
    "numbering",
    "markdown",
    "documentation",
    "ai-agent",
    "claude-code",
    "codex",
    "naming-convention",
    "korean",
    "i18n"
  ],
  "type": "module",
  "bin": {
    "docs-numbering": "bin/docs-numbering.js",
    "docnum": "bin/docs-numbering.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.6.0",
    "@sindresorhus/slugify": "^2.2.1",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "prettier": "^3.3.0"
  }
}
